DISCORD_TOKEN=your_discord_bot_token_here
SPREADSHEET_ID=your_spreadsheet_id_here
APPROVAL_ROLE_ID=000000000000000000
# 開発時のみ設定（ギルド登録で即時反映）。本番では削除またはコメントアウト。
GUILD_ID=000000000000000000
# 32バイト（64文字の16進数）の暗号化キー。以下のコマンドで生成できる:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_key_here
# Google サービスアカウントの credentials.json の中身をそのままJSON文字列として貼る（Railway等コンテナ環境用）
# ローカル開発では未設定のままでも credentials.json ファイルがあれば動作する
GOOGLE_CREDENTIALS_JSON=
